<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="@color/white"
    android:padding="32dp">

    <ImageView
        android:id="@+id/iv_splash_logo"
        android:layout_width="160dp"
        android:layout_height="160dp"
        android:src="@drawable/ic_splash_animal"
        android:contentDescription="Logo Aplikasi"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="NusantaraWild"
        android:textSize="26sp"
        android:textColor="@color/teal_700"
        android:fontFamily="@font/poppins_bold"
        android:layout_marginTop="20dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/ensiklopedia_spesies_endemik_indonesia"
        android:textSize="12sp"
        android:textColor="@color/text_secondary"
        android:fontFamily="@font/poppins_regular"
        android:layout_marginTop="4dp"
        android:gravity="center"/>

    <ProgressBar
        android:id="@+id/progress_bar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="40dp"
        android:indeterminateTint="@color/teal_500"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_lanjut"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/memuat_data"
        android:enabled="false"
        android:visibility="gone"
        android:fontFamily="@font/poppins_medium"
        app:backgroundTint="@color/teal_700"
        app:cornerRadius="24dp"
        android:paddingHorizontal="32dp"
        android:layout_marginTop="20dp"/>

</LinearLayout>